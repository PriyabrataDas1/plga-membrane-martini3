integrator      = steep
emtol           = 1000.0
emstep          = 0.01
nsteps          = 50000

cutoff-scheme   = Verlet
nstlist         = 20
pbc             = xyz

coulombtype     = reaction-field
rcoulomb        = 1.1
epsilon_r       = 15

vdw_type        = cutoff
rvdw            = 1.1

constraints     = none
